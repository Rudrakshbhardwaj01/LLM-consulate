# NVIDIA Inference API
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# development | production (production requires NVIDIA_API_KEY + CORS_ORIGINS in env)
APP_ENV=development

# Chief Analyst synthesizes consensus (registry ID)
SYNTHESIS_MODEL_ID=gpt-oss-120b

# Constitutional crisis threshold (0.0–1.0)
DEADLOCK_THRESHOLD=0.60

# Provider retries on 429/5xx
PROVIDER_MAX_RETRIES=3
PROVIDER_TIMEOUT_SECONDS=180
PROVIDER_CONNECT_TIMEOUT_SECONDS=15

# Max seconds per council member before timeout (consulate mode)
CONSULATE_MODEL_TIMEOUT=45

# Fast path by default (heuristic claims, no extra LLM round-trips during analysis).
# AGREEMENT_USE_LLM=true enables legacy full LLM claim extraction + judge.
# AGREEMENT_USE_LLM_JUDGE=true runs judge only on deadlocks.
# AGREEMENT_USE_EMBEDDINGS=true calls the NVIDIA embeddings API (10% weight).

# Guest session limits
SESSION_REQUEST_LIMIT=15

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
